            "url": { "raw": "{{base_url}}/api/auth/register", "host": ["{{base_url}}"], "path": ["api", "auth", "register"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Amaka Johnson\",\n  \"email\": \"amaka@example.com\",\n  \"password\": \"password123\",\n  \"role\": \"HOUSEHOLD\",\n  \"phone\": \"08012345678\",\n  \"address\": \"15 Adeola Odeku, Victoria Island\",\n  \"latitude\": 6.4281,\n  \"longitude\": 3.4219,\n  \"lga\": \"Eti-Osa\",\n  \"state\": \"Lagos\"\n}"
            }
          }
        },
